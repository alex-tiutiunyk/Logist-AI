# Copy to .env.staging and fill in real values before deploying

# Postgres
POSTGRES_USER=logist
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=logistics

# JWT — use a long random secret in production
JWT_SECRET=change_me_long_random_secret
JWT_EXPIRES_IN=8h

# Public URL of the staging frontend (used for CORS and WebSocket URL)
# e.g. http://staging.example.com or http://<server-ip>
FRONTEND_URL=http://staging.example.com

# Port exposed by nginx on the host
STAGING_PORT=80
